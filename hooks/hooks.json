{
  "description": "Token Saver — compresses CLI output to save LLM context tokens",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/hook.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
